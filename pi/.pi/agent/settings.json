{
  "lastChangelogVersion": "0.80.3",
  "theme": "light",
  "defaultProvider": " opencode-go",
  "defaultModel": "glm-5.2",
  "defaultThinkingLevel": "high",
  "terminal": {
    "showTerminalProgress": true
  },
  "treeFilterMode": "default",
  "packages": [
    "npm:pi-subagents",
    "npm:@gotgenes/pi-permission-system",
    "npm:pi-web-access"
  ],
  "subagents": {
    "defaultModel": "qwen-3.7-max",
    "agentOverrides": {
      "scout": {
        "thinking": "high",
        "model": "deepseek-v4-pro"
      },
      "context-builder": {
        "thinking": "high",
        "model": "glm-5.2"
      },
      "planner": {
        "thinking": "high",
        "model": "glm-5.2"
      },
      "researcher": {
        "thinking": "high",
        "model": "kimi-k2.7-code"
      },
      "worker": {
        "thinking": "medium",
        "model": "qwen-3.7-max"
      },
      "reviewer": {
        "thinking": "high",
        "model": "kimi-k2.7-code"
      },
      "oracle": {
        "thinking": "high",
        "model": "qwen-3.7-max"
      }
    }
  }
}