{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "snapshot": true,
  "autoupdate": true,
  "share": "manual",
  "permission": {
    "read": {
      "*": "allow"
    },
    "glob": {
      "*": "allow"
    },
    "bash": {
      "*": "ask",
      "mkdir*": "allow",
      "ls*": "allow",
      "cat*": "allow",
      "grep*": "allow",
      "find*": "allow",
      "sort*": "allow",
      "head*": "allow",
      "tail*": "allow",
      "bash -n*": "allow",
      "shellcheck*": "allow"
    }
  },
  "agent": {
    "java-modernizer": {
      "description": "Modernizes Java projects",
      "mode": "subagent"
    }
  },
  "provider": {
    "Unsloth MLX (local)": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Unsloth MLX (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "unsloth/gemma-4-26b-a4b-it-UD-MLX-4bit": {
          "name": "Gemma-4-26b-a4b-it-UD-MLX-4bit"
        }
      }
    }
  }
}
